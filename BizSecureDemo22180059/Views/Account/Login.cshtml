@model BizSecureDemo22180059.ViewModels.LoginVm

<div class="card shadow-sm mx-auto" style="max-width: 400px;">
    <div class="card-body">
        <h3 class="card-title text-center mb-4">Вход</h3>
        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input class="form-control" asp-for="Email" />
            </div>
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input class="form-control" asp-for="Password" type="password" />
            </div>
            <div class="text-danger small mb-3">
                @foreach (var state in ViewContext.ModelState.Values)
                {
                    foreach (var error in state.Errors)
                    {
                        <div>@error.ErrorMessage</div>
                    }
                }
            </div>
            <button class="btn btn-success w-100" type="submit">Login</button>
        </form>
        <div class="mt-3 text-center">
            <a asp-action="Register" class="small">Нямаш акаунт? Register</a>
        </div>
    </div>
</div>      